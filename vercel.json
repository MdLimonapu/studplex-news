{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/api/robots.txt" },
    { "source": "/", "destination": "/api/page/home" },
    { "source": "/country/:name", "destination": "/index.html" },
    { "source": "/:slug", "destination": "/api/page/:slug" }
  ],
  "crons": [
    {
      "path": "/api/write-articles",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/fetch-news",
      "schedule": "0 5 * * *"
    }
  ]
}
